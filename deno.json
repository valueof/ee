{
  "tasks": {
    "dev": "deno run --allow-run --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-run --allow-env --allow-read --allow-write",
    "build": "deno compile --allow-run --allow-env --allow-read --output dist/git-ed src/main.ts",
    "install": "deno task build && mkdir -p \"$HOME/.local/bin\" && cp dist/git-ed \"$HOME/.local/bin/git-ed\" && chmod +x \"$HOME/.local/bin/git-ed\""
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.ns", "es2023"]
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true
  }
}
